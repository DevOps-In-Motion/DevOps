# OIDC configuration values for kubeadm (IdP-agnostic).
# Durable path: these become apiServer.extraArgs in ClusterConfiguration.
# They survive destroy/recreate because they are part of kubeadm init — not
# post-hoc edits to /etc/kubernetes/manifests/kube-apiserver.yaml.
#
#   cp k8s/oidc/placeholders.env.example k8s/oidc/placeholders.env
#   bash k8s/oidc/apiserver/render-kubeadm-oidc.sh
#
# Until an IdP exists, keep the example.invalid issuer — kube-apiserver still
# starts (client-cert admin auth works). Token login fails until the IdP is real.

# --- Apiserver OIDC flags ---
OIDC_ISSUER_URL=https://oidc.example.invalid/realms/REPLACE_ME
OIDC_CLIENT_ID=kubernetes
OIDC_USERNAME_CLAIM=email
OIDC_GROUPS_CLAIM=groups
OIDC_USERNAME_PREFIX=oidc:
OIDC_GROUPS_PREFIX=oidc:
OIDC_CA_FILE=/etc/kubernetes/pki/oidc-ca.crt

# --- Group names (IdP group claim → apiserver subject after prefix) ---
# Binding subjects = "${OIDC_GROUPS_PREFIX}${GROUP_*}" e.g. oidc:platform-admins
GROUP_PLATFORM_ADMIN=platform-admins
GROUP_NAMESPACE_DEV=namespace-devs
GROUP_READONLY_VIEWER=readonly-viewers

# --- Single app namespace (admin creates; developers/viewers work inside it) ---
# Matches this lab's nginx-app (see k8s/admin/nginx-ns-rolebinding.yaml).
NAMESPACE=nginx-app

# --- Where to push ClusterConfiguration (multi-CP kubeadm phase apply) ---
CONTROL_PLANE_HOSTS=192.168.56.101
SSH_USER=vagrant
