{
  "realm": "rascaas",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      { "name": "admins", "description": "RaSCaaS operators" }
    ]
  },
  "groups": [
    {
      "name": "admins",
      "realmRoles": ["admins"]
    }
  ],
  "users": [
    {
      "username": "dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "Operator",
      "email": "dev@kovr.ai",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "groups": ["admins"],
      "realmRoles": ["admins"]
    }
  ],
  "clients": [
    {
      "clientId": "platform-ui",
      "name": "RaSCaaS local UI",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "rascaas-local-client-secret",
      "redirectUris": [
        "http://localhost:4180/oauth2/callback"
      ],
      "webOrigins": [
        "http://localhost:4180"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
