# Copy to .env: cp .env.example .env
#
# Local OAuth stack (docker compose):
#   docker compose up --build
#   App:      http://localhost:4180  (via oauth2-proxy)
#   Keycloak: http://localhost:8080  (admin/admin, test user dev/dev)

ENVIRONMENT=production
APP_BASE_URL=http://localhost:4180
APP_VERSION=0.1.0
HELM_CHART_VERSION=0.1.0
DEFAULT_WORKFLOW=uat-deploy.yml

# OIDC (Keycloak realm imported from docker/keycloak/realm-rascaas.json)
OIDC_ISSUER_URL=http://localhost:8080/realms/rascaas
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/rascaas
# JWKS fetch from inside Docker (Keycloak metadata often lists localhost)
OIDC_JWKS_URL=http://keycloak:8080/realms/rascaas/protocol/openid-connect/certs
OIDC_CLIENT_ID=platform-ui
# Docker Compose sets TRUST_OAUTH2_PROXY_IDENTITY=true on the rascaas service.
TRUST_OAUTH2_PROXY_IDENTITY=false
OAUTH2_PROXY_CLIENT_SECRET=rascaas-local-client-secret
OAUTH2_PROXY_REDIRECT_URL=http://localhost:4180/oauth2/callback
# oauth2-proxy: exactly 16, 24, or 32 ASCII bytes. Use 32 for max strength (192-bit entropy):
#   python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(24)).decode().rstrip('='))"
OAUTH2_PROXY_COOKIE_SECRET=

# GitHub App — leave installation id 0 / private key empty for mock API in local dev
# JWT iss: GITHUB_CLIENT_ID if set, else GITHUB_APP_ID (GitHub accepts either)
GITHUB_APP_ID=0
GITHUB_CLIENT_ID=
GITHUB_INSTALLATION_ID=0
GITHUB_PRIVATE_KEY=
# Platform repo on GitHub (owner/repo). Local clone folder is platform-testing/; GitHub repo name is platform.
# All UAT builds/deploys run here. variance_repo in dispatch = service selected in the UI.
GITHUB_DISPATCH_REPO=kovr-ai/platform
